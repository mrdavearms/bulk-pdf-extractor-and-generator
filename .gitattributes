# Auto-detect text files and normalise line endings
* text=auto

# Force LF for source files (consistent across Windows/macOS)
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.spec text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Binary files — no line-ending conversion
*.png binary
*.ico binary
*.icns binary
*.pdf binary
*.exe binary
*.dmg binary
